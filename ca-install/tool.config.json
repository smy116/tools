{
  "slug": "ca-install",
  "title": "ca-install",
  "category": "根证书安装",
  "summary": "把 SMY Root Certification Authority ECC 安装到 Linux、Windows、macOS 和 Android 的系统信任库，也支持直接下载证书文件。",
  "platforms": [
    "Linux",
    "Windows",
    "macOS",
    "Android"
  ],
  "tags": [
    "root",
    "sudo",
    "管理员",
    "证书",
    "Magisk",
    "KernelSU",
    "APatch"
  ],
  "order": 20,
  "accent": "sky",
  "sourceFiles": [
    {
      "id": "linux",
      "path": "Install-To-Linux.sh",
      "route": "/source/ca-install/linux.sh",
      "filename": "Install-To-Linux.sh",
      "contentType": "text/x-shellscript; charset=utf-8",
      "label": "Linux CA 安装脚本",
      "delivery": "asset",
      "envKey": "CA_INSTALL_URL_LINUX"
    },
    {
      "id": "windows",
      "path": "Install-To-Windows.ps1",
      "route": "/source/ca-install/windows.ps1",
      "filename": "Install-To-Windows.ps1",
      "contentType": "text/plain; charset=utf-8",
      "label": "Windows CA 安装脚本",
      "delivery": "asset",
      "envKey": "CA_INSTALL_URL_WINDOWS"
    },
    {
      "id": "mac",
      "path": "Install-To-Mac.sh",
      "route": "/source/ca-install/mac.sh",
      "filename": "Install-To-Mac.sh",
      "contentType": "text/x-shellscript; charset=utf-8",
      "label": "macOS CA 安装脚本",
      "delivery": "asset",
      "envKey": "CA_INSTALL_URL_MAC"
    },
    {
      "id": "cert",
      "path": "SMY-Root-CA.crt",
      "route": "/source/ca-install/root-ca.crt",
      "filename": "SMY-Root-CA.crt",
      "contentType": "application/x-x509-ca-cert",
      "label": "SMY 根证书文件",
      "delivery": "asset",
      "envKey": "CA_CERT_URL"
    },
    {
      "id": "androidModule",
      "path": "magisk-android.zip",
      "route": "/source/ca-install/magisk-android.zip",
      "filename": "magisk-android.zip",
      "contentType": "application/zip",
      "label": "Android Root CA 模块",
      "delivery": "asset",
      "envKey": "CA_ANDROID_MODULE_URL"
    }
  ],
  "commands": [
    {
      "id": "ca-linux",
      "title": "Linux 安装",
      "description": "将证书安装到 Linux 系统信任库。",
      "platform": "Linux",
      "language": "bash",
      "badges": [
        "root"
      ],
      "template": "bash -c 'bash <(curl -fsSL \"$1\")' _ \"{{source:linux}}\""
    },
    {
      "id": "ca-windows",
      "title": "Windows 安装",
      "description": "使用一行 PowerShell 命令安装到系统信任库，并自动请求管理员权限。",
      "platform": "Windows",
      "language": "powershell",
      "badges": [
        "管理员"
      ],
      "template": "$SmyCaInstallUrl=\"{{source:windows}}\"; irm $SmyCaInstallUrl | iex"
    },
    {
      "id": "ca-macos",
      "title": "macOS 安装",
      "description": "下载安装脚本，并安装到系统钥匙串。",
      "platform": "macOS",
      "language": "bash",
      "badges": [
        "sudo"
      ],
      "template": "bash -c 'bash <(curl -fsSL \"$1\")' _ \"{{source:mac}}\""
    },
    {
      "id": "ca-cert",
      "title": "证书文件",
      "description": "直接下载 SMY Root CA 证书文件。",
      "platform": "通用",
      "language": "bash",
      "badges": [
        "crt"
      ],
      "template": "curl -fsSL {{source:cert}} -o SMY-Root-CA.crt"
    },
    {
      "id": "ca-android-module",
      "title": "Android 模块",
      "description": "下载可在 Magisk、KernelSU 或 APatch 中安装的 Android Root CA 模块。",
      "platform": "Android",
      "language": "bash",
      "badges": [
        "Magisk",
        "KernelSU",
        "APatch",
        "root"
      ],
      "template": "curl -fsSL {{source:androidModule}} -o magisk-android.zip"
    }
  ]
}
